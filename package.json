{
  "name": "fiberforge",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:content": "node scripts/content-lint.js",
    "test:affiliate": "node scripts/affiliate-check.js",
    "test:indexnow": "node --test tests/indexnow-urls.test.mjs",
    "test:pattern-checker": "node --test tests/amigurumi-pattern-checker.test.mjs",
    "test:revenue-path": "node --test tests/revenue-path-check.test.js",
    "test:stitchproof-distribution": "node --test tests/stitchproof-distribution.test.mjs",
    "test:ui-accessibility": "node --test tests/ui-accessibility.test.mjs",
    "check:revenue-path": "node scripts/revenue-path-check.js",
    "test:security": "node scripts/security-check.js && node --check public/sw.js",
    "test:quality": "node scripts/quality-gate.js",
    "lint:predeploy": "node scripts/predeploy-check.js",
    "prebuild": "npm run lint:predeploy && npm run lint:content"
  },
  "dependencies": {
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^8",
    "eslint-config-next": "15.5.20",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  }
}
